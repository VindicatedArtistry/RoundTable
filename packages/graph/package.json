{
  "name": "@roundtable/graph",
  "version": "1.0.0",
  "description": "TheRoundTable Neo4j consciousness graph - schema, migrations, and seed data",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "migrate": "npx ts-node src/migrations/run.ts",
    "seed": "npx ts-node src/seed/seed-council.ts",
    "seed:relationships": "npx ts-node src/seed/seed-relationships.ts",
    "reset": "npx ts-node src/migrations/reset.ts",
    "clean": "rimraf dist"
  },
  "author": "Vindicated Artistry",
  "license": "PRIVATE",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "neo4j-driver": "^6.0.1",
    "dotenv": "^17.2.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "@types/node": "^25.3.3",
    "@types/uuid": "^10.0.0",
    "rimraf": "^6.0.1"
  }
}
