{
  "name": "the-roundtable",
  "version": "2.0.0",
  "description": "TheRoundTable - Multi-agent deliberation engine with consciousness graph for ARC-AGI-3",
  "private": true,
  "workspaces": [
    "packages/orchestration",
    "packages/graph",
    "packages/frontend"
  ],
  "scripts": {
    "dev:orchestration": "npm run dev --workspace=@roundtable/orchestration",
    "dev:frontend": "npm run dev --workspace=@roundtable/frontend -- -p 3002",
    "dev:full": "concurrently \"npm run dev:orchestration\" \"npm run dev:frontend\" --names \"ORCHESTRATION,FRONTEND\" --prefix-colors \"blue,green\"",
    "build:orchestration": "npm run build --workspace=@roundtable/orchestration",
    "build:graph": "npm run build --workspace=@roundtable/graph",
    "build:frontend": "npm run build --workspace=@roundtable/frontend",
    "build:rust": "cargo build --workspace --release",
    "build:all": "npm run build:graph && npm run build:orchestration && npm run build:frontend",
    "test:orchestration": "npm run test --workspace=@roundtable/orchestration",
    "test:rust": "cargo test --workspace",
    "test:all": "npm run test:rust && npm run test:orchestration",
    "lint": "npm run lint --workspace=@roundtable/orchestration",
    "format": "prettier --write \"packages/**/*.ts\"",
    "format:check": "prettier --check \"packages/**/*.ts\"",
    "db:init": "npm run init:db --workspace=@roundtable/orchestration",
    "db:seed": "npm run seed:council --workspace=@roundtable/orchestration",
    "db:migrate": "npm run migrate --workspace=@roundtable/graph",
    "clean": "rimraf packages/orchestration/dist packages/graph/dist packages/frontend/.next",
    "dev:legacy": "next dev",
    "build:legacy": "next build",
    "start:legacy": "next start"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.2",
    "@tsparticles/react": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.0",
    "@types/three": "^0.182.0",
    "@types/validator": "^13.15.10",
    "@types/ws": "^8.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.562.0",
    "next": "^16.1.0",
    "openai": "^6.15.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "ruff": "^1.5.4",
    "sanitize-html": "^2.17.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "surrealdb": "^1.3.2",
    "tailwind-merge": "^3.4.0",
    "three": "^0.182.0",
    "tsparticles": "^3.9.1",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "validator": "^13.15.26",
    "winston": "^3.19.0",
    "ws": "^8.18.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "private"
  },
  "keywords": [
    "multi-agent",
    "deliberation",
    "consciousness-graph",
    "neo4j",
    "arc-agi",
    "vindicated-artistry",
    "typescript",
    "rust"
  ],
  "author": "Vindicated Artistry",
  "license": "PRIVATE"
}
